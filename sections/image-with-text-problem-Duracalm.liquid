<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,0">

{%- style -%}
  /* Font imports must be at top of stylesheet */
  {% case section.settings.body_font_family %}
    {% when 'merriweather' %}
      @import url('https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700&display=swap');
    {% when 'source_serif' %}
      @import url('https://fonts.googleapis.com/css2?family=Source+Serif+Pro:wght@300;400;600;700&display=swap');
    {% when 'libre_baskerville' %}
      @import url('https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap');
    {% when 'lora' %}
      @import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap');
  {% endcase %}

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.mobile_padding_top }}px;
    padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.desktop_padding_top }}px;
      padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
    }

    #image-with-text-{{ section.id }} .image-with-text__media-item {
      width: {{ section.settings.desktop_media_width }}%;
    }
    #image-with-text-{{ section.id }} .image-with-text__text-item {
      width: {{ 100 | minus: section.settings.desktop_media_width }}%;
    }
  }

  {%- if section.settings.scrollable_text -%}
    /* Desktop scrollable text wrapper - contains all content blocks */
    @media screen and (min-width: 750px) {
      #image-with-text-{{ section.id }} .image-with-text__text-scrollable-wrapper {
        overflow-y: auto;
        overflow-x: visible;
        padding-right: 12px;
        max-height: 500px;
        display: block;
      }
      #image-with-text-{{ section.id }} .image-with-text__text-scrollable-wrapper::-webkit-scrollbar {
        width: 6px;
      }
      #image-with-text-{{ section.id }} .image-with-text__text-scrollable-wrapper::-webkit-scrollbar-track {
        background: rgba(123, 146, 200, 0.15);
        border-radius: 3px;
      }
      #image-with-text-{{ section.id }} .image-with-text__text-scrollable-wrapper::-webkit-scrollbar-thumb {
        background: #7b92c8;
        border-radius: 3px;
      }
      #image-with-text-{{ section.id }} .image-with-text__text-scrollable-wrapper::-webkit-scrollbar-thumb:hover {
        background: #6a7fb0;
      }
    }
    /* Mobile scrollable text wrapper */
    @media screen and (max-width: 749px) {
      #image-with-text-{{ section.id }} .image-with-text__text-scrollable-wrapper {
        overflow-y: auto;
        overflow-x: visible;
        padding-right: 12px;
        max-height: 400px;
        display: block;
      }
      #image-with-text-{{ section.id }} .image-with-text__text-scrollable-wrapper::-webkit-scrollbar {
        width: 4px;
      }
      #image-with-text-{{ section.id }} .image-with-text__text-scrollable-wrapper::-webkit-scrollbar-track {
        background: rgba(123, 146, 200, 0.15);
        border-radius: 2px;
      }
      #image-with-text-{{ section.id }} .image-with-text__text-scrollable-wrapper::-webkit-scrollbar-thumb {
        background: #7b92c8;
        border-radius: 2px;
      }
      #image-with-text-{{ section.id }} .image-with-text__text-scrollable-wrapper::-webkit-scrollbar-thumb:hover {
        background: #6a7fb0;
      }
    }
  {%- endif -%}

  /* Magic Mind style button */
  .mm-style-btn-{{ section.id }} {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    text-transform: none;
    border: 2px solid #7B92C8;
    border-radius: 8px;
    color: #7B92C8;
    background: transparent;
    cursor: pointer;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
    z-index: 1;
  }
  .mm-style-btn-{{ section.id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #7B92C8 0%, #ddbea8 50%, #f3dfc1 100%);
    background-size: 200% 200%;
    opacity: 0;
    transition: opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: -1;
  }
  .mm-style-btn-{{ section.id }}:hover::before {
    opacity: 1;
    background-position: 100% 0;
    animation: gradientShift-{{ section.id }} 0.6s ease forwards;
  }
  .mm-style-btn-{{ section.id }}:hover {
    color: #ffffff;
    border-color: transparent;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(123, 146, 200, 0.3);
  }
  @keyframes gradientShift-{{ section.id }} {
    0% { background-position: 0% 50%; }
    100% { background-position: 100% 50%; }
  }
  /* Mobile adjustments */
  @media screen and (max-width: 749px) {
    .mm-style-btn-{{ section.id }} {
      padding: 12px 24px;
      font-size: 14px;
    }
  }

  {%- if section.settings.enable_rotating_images -%}
    .rotating-images-container-{{ section.id }} {
      position: relative;
      width: 100%;
      height: 100%;
    }
    .rotating-images-container-{{ section.id }} .rotating-images-wrapper {
      position: relative;
      width: 100%;
      height: 100%;
    }
    .rotating-images-container-{{ section.id }} .rotating-image {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
      transition: opacity {{ section.settings.rotation_interval | divided_by: 3.0 }}s ease-in-out;
      pointer-events: none;
    }
    .rotating-images-container-{{ section.id }} .rotating-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .rotating-images-container-{{ section.id }} .rotating-image--active {
      opacity: 1;
      pointer-events: auto;
    }
  {%- endif -%}

  .color-scheme-{{ section.id }}.color-custom {
    --color-background: {{ section.settings.custom_colors_background.red }}, {{ section.settings.custom_colors_background.green }}, {{ section.settings.custom_colors_background.blue }};
    --gradient-background: {% if section.settings.custom_gradient_background != blank %}{{ section.settings.custom_gradient_background }}{% else %}{{ section.settings.custom_colors_background }}{% endif %};
    --color-foreground: {{ section.settings.custom_colors_text.red }}, {{ section.settings.custom_colors_text.green }}, {{ section.settings.custom_colors_text.blue }};
    --color-button: {{ section.settings.custom_colors_solid_button_background.red }}, {{ section.settings.custom_colors_solid_button_background.green }}, {{ section.settings.custom_colors_solid_button_background.blue }};
    --color-button-text: {{ section.settings.custom_colors_solid_button_text.red }}, {{ section.settings.custom_colors_solid_button_text.green }}, {{ section.settings.custom_colors_solid_button_text.blue }};
    --color-base-outline-button-labels: {{ section.settings.custom_colors_outline_button.red }}, {{ section.settings.custom_colors_outline_button.green }}, {{ section.settings.custom_colors_outline_button.blue }};
  }

  .section-color-scheme-{{ section.id }}.color-custom {
    --color-background: {{ section.settings.custom_section_colors_background.red }}, {{ section.settings.custom_section_colors_background.green }}, {{ section.settings.custom_section_colors_background.blue }};
    --gradient-background: {% if section.settings.custom_section_gradient_background != blank %}{{ section.settings.custom_section_gradient_background }}{% else %}{{ section.settings.custom_section_colors_background }}{% endif %};
  }

  /* Typography & Readability Styles */
  #image-with-text-{{ section.id }} .image-with-text__text.rte {
    max-width: {{ section.settings.text_max_width }}ch;
    line-height: {{ section.settings.line_height }};
    font-size: {{ section.settings.font_size_scale }}%;
  }

  #image-with-text-{{ section.id }} .image-with-text__text.rte p {
    margin-bottom: {{ section.settings.paragraph_spacing }}em;
  }

  #image-with-text-{{ section.id }} .image-with-text__text.rte p:last-child {
    margin-bottom: 0;
  }

  /* Font Family */
  {% case section.settings.body_font_family %}
    {% when 'serif' %}
      #image-with-text-{{ section.id }} .image-with-text__text.rte {
        font-family: Georgia, "Times New Roman", serif;
      }
    {% when 'georgia' %}
      #image-with-text-{{ section.id }} .image-with-text__text.rte {
        font-family: Georgia, serif;
      }
    {% when 'merriweather' %}
      #image-with-text-{{ section.id }} .image-with-text__text.rte {
        font-family: "Merriweather", Georgia, serif;
      }
    {% when 'source_serif' %}
      #image-with-text-{{ section.id }} .image-with-text__text.rte {
        font-family: "Source Serif Pro", Georgia, serif;
      }
    {% when 'libre_baskerville' %}
      #image-with-text-{{ section.id }} .image-with-text__text.rte {
        font-family: "Libre Baskerville", Georgia, serif;
      }
    {% when 'lora' %}
      #image-with-text-{{ section.id }} .image-with-text__text.rte {
        font-family: "Lora", Georgia, serif;
      }
  {% endcase %}

  /* Text Color Hierarchy */
  #image-with-text-{{ section.id }} .image-with-text__heading {
    color: {{ section.settings.heading_text_color }};
  }

  #image-with-text-{{ section.id }} .image-with-text__text.rte {
    color: {{ section.settings.body_text_color }};
  }

  #image-with-text-{{ section.id }} .image-with-text__text.rte strong,
  #image-with-text-{{ section.id }} .image-with-text__text.rte b {
    color: {{ section.settings.accent_text_color }};
  }

  /* Pull Quote Block Styles */
  #image-with-text-{{ section.id }} blockquote.pull-quote {
    position: relative;
    font-size: {{ section.settings.pull_quote_font_scale }}%;
    line-height: {{ section.settings.pull_quote_line_height }};
    color: {{ section.settings.pull_quote_text_color }};
    background: {{ section.settings.pull_quote_bg_color }};
    border-left: {{ section.settings.pull_quote_border_width }}px solid {{ section.settings.pull_quote_border_color }};
    padding: {{ section.settings.pull_quote_padding }}px;
    margin: {{ section.settings.pull_quote_margin_y }}px 0;
    font-style: italic;
  }

  #image-with-text-{{ section.id }} blockquote.pull-quote p {
    margin-bottom: 0;
  }

  #image-with-text-{{ section.id }} blockquote.pull-quote p:last-child {
    margin-bottom: 0;
  }

  {%- if section.settings.pull_quote_quotation_marks -%}
    #image-with-text-{{ section.id }} blockquote.pull-quote::before {
      content: '"';
      position: absolute;
      top: -8px;
      left: 8px;
      font-size: 3em;
      color: {{ section.settings.pull_quote_border_color }};
      opacity: {{ section.settings.pull_quote_quotation_opacity | divided_by: 100.0 }};
      font-family: Georgia, serif;
      line-height: 1;
      pointer-events: none;
    }
  {%- endif -%}

  /* Icon Anchor Styles */
  #image-with-text-{{ section.id }} .icon-anchor {
    display: flex;
    align-items: {{ section.settings.icon_anchor_vertical_align }};
    gap: {{ section.settings.icon_anchor_icon_spacing }}px;
    margin-top: {{ section.settings.icon_anchor_margin_top }}px;
    margin-bottom: {{ section.settings.icon_anchor_margin_bottom }}px;
  }

  #image-with-text-{{ section.id }} .icon-anchor__icon {
    flex-shrink: 0;
    width: {{ section.settings.icon_anchor_icon_size }}px;
    height: {{ section.settings.icon_anchor_icon_size }}px;
    color: {{ section.settings.icon_anchor_icon_color }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #image-with-text-{{ section.id }} .icon-anchor__icon .material-symbols-rounded {
    font-size: {{ section.settings.icon_anchor_icon_size }}px;
    color: {{ section.settings.icon_anchor_icon_color }};
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }

  #image-with-text-{{ section.id }} .icon-anchor__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  #image-with-text-{{ section.id }} .icon-anchor__text {
    font-size: {% case section.settings.icon_anchor_subhead_size %}{% when 'small' %}1{% when 'medium' %}1.1{% when 'large' %}1.2{% endcase %}em;
    font-weight: {{ section.settings.icon_anchor_subhead_weight }};
    color: {{ section.settings.icon_anchor_subhead_color }};
    line-height: 1.3;
  }
{%- endstyle -%}

{%- liquid
  if section.settings.section_color_scheme == section.settings.color_scheme
    assign no_content_background = true
  endif
  if section.settings.section_color_scheme == 'custom' and section.settings.color_scheme == 'custom'
    unless section.settings.custom_colors_background == section.settings.custom_section_colors_background
      assign no_content_background = false
    endunless
  endif

  if settings.text_boxes_shadow_opacity == 0 and settings.text_boxes_border_thickness == 0 or settings.text_boxes_border_opacity == 0
    assign no_content_styles = true
  endif

  if no_content_background and no_content_styles
    assign padding_class = ' collapse-padding'
    assign same_bgs = true
  endif
-%}

<div id="image-with-text-{{ section.id }}" class="section-color-scheme-{{ section.id }} color-{{ section.settings.section_color_scheme }} gradient content-for-grouping animate-section animate--hidden {{ section.settings.visibility }}">
  {% if section.settings.display_id %}
    <copy-button class="section-id-btn button" data-content="#shopify-section-{{ section.id }}" data-success="false">
      <span class="copy-text">Click to copy section ID</span>
      <span class="copy-success">ID copied successfully!</span>
    </copy-button>
  {% endif %}
  <div class="image-with-text image-with-text--{{ section.settings.content_layout }} image-with-text--mobile-{{ section.settings.mobile_direction }}{% if section.settings.full_desktop_width and section.settings.content_layout != 'overlap' %} image-with-text--desktop-full-width{% endif %} page-width isolate{% if settings.text_boxes_border_thickness > 0 and settings.text_boxes_border_opacity > 0 and settings.media_border_thickness > 0 and settings.media_border_opacity > 0 %} collapse-borders{% endif %}{% unless section.settings.color_scheme == 'background-1' and settings.media_border_thickness > 0 and settings.text_boxes_shadow_opacity == 0 and settings.text_boxes_border_thickness == 0 or settings.text_boxes_border_opacity == 0 %} collapse-corners{% endunless %}{% if same_bgs %} same-colors{% else %} different-colors{% endif %}{{ padding_class }} section-{{ section.id }}-padding">
    <div class="image-with-text__grid grid grid--gapless grid--1-col{% if section.settings.layout == 'text_first' %} image-with-text__grid--reverse{% endif %} animate-item">
      <div class="image-with-text__media-item image-with-text__media-item--{{ section.settings.desktop_content_position }}{% if section.settings.mobile_full_media_width %} image-with-text__media--mobile-full{% endif %} grid__item">
        <div
          class="image-with-text__media image-with-text__media--{{ section.settings.height }} gradient color-scheme-{{ section.id }} color-{{ section.settings.color_scheme }} global-media-settings {% if section.settings.image != blank or section.settings.video != blank %}media{% else %}image-with-text__media--placeholder placeholder{% endif %}"
          {% if section.settings.height == 'adapt' and section.settings.video != blank %}
            style="padding-bottom: {{ 1 | divided_by: section.settings.video.aspect_ratio | times: 100 }}%;"
          {% elsif section.settings.height == 'adapt' and section.settings.image != blank %}
            style="padding-bottom: {{ 1 | divided_by: section.settings.image.aspect_ratio | times: 100 }}%;"
          {% endif %}
        >
          {%- if section.settings.enable_rotating_images -%}
            {%- capture sizes -%}
              (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px,
              (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / {{ section.settings.mobile_image_quanlity }})
            {%- endcapture -%}
            <div class="rotating-images-container-{{ section.id }}" data-section-id="{{ section.id }}" data-interval="{{ section.settings.rotation_interval | times: 1000 }}">
              <div class="rotating-images-wrapper">
                {%- if section.settings.image != blank -%}
                  <div class="rotating-image rotating-image--active">
                    {{ section.settings.image | image_url: width: 1500 | image_tag: loading: 'lazy', sizes: sizes, widths: '165, 360, 535, 750, 1070, 1500' }}
                  </div>
                {%- endif -%}
                {%- if section.settings.image_2 != blank -%}
                  <div class="rotating-image">
                    {{ section.settings.image_2 | image_url: width: 1500 | image_tag: loading: 'lazy', sizes: sizes, widths: '165, 360, 535, 750, 1070, 1500' }}
                  </div>
                {%- endif -%}
                {%- if section.settings.image_3 != blank -%}
                  <div class="rotating-image">
                    {{ section.settings.image_3 | image_url: width: 1500 | image_tag: loading: 'lazy', sizes: sizes, widths: '165, 360, 535, 750, 1070, 1500' }}
                  </div>
                {%- endif -%}
                {%- if section.settings.image_4 != blank -%}
                  <div class="rotating-image">
                    {{ section.settings.image_4 | image_url: width: 1500 | image_tag: loading: 'lazy', sizes: sizes, widths: '165, 360, 535, 750, 1070, 1500' }}
                  </div>
                {%- endif -%}
                {%- if section.settings.image_5 != blank -%}
                  <div class="rotating-image">
                    {{ section.settings.image_5 | image_url: width: 1500 | image_tag: loading: 'lazy', sizes: sizes, widths: '165, 360, 535, 750, 1070, 1500' }}
                  </div>
                {%- endif -%}
              </div>
            </div>
          {%- elsif section.settings.video != blank -%}
            <internal-video{% if section.settings.video_autoplay %} data-autoplay="true" data-no-play-btn="true"{% endif %}>
              <video
                poster="{{ section.settings.video.preview_image | image_url }}"
                {% if section.settings.video_loop %} loop{% endif %}
                {% if section.settings.video_autoplay %} muted{% endif %}
                width="100%" height="auto" preload="metadata" playsinline disablepictureinpicture
              >
                {% for source in section.settings.video.sources %}
                  <source
                    {% if section.settings.video_autoplay %}data-{% endif %}src="{{ source.url }}"
                    type="{{ source.mime_type }}"
                  >
                {% endfor %}
              </video>
              <button class="internal-video__play"{% if section.settings.video_autoplay %} style='visibility: hidden;'{% endif %}>
                <div class="play-button color-accent-1">
                  {%- render 'icon-play' -%}
                </div>
              </button>
            </internal-video>
          {%- elsif section.settings.image != blank -%}
            {%- capture sizes -%}
              (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px,
              (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / {{ section.settings.mobile_image_quanlity }})
            {%- endcapture -%}
            {{
              section.settings.image
              | image_url: width: 1500
              | image_tag: loading: 'lazy', sizes: sizes, widths: '165, 360, 535, 750, 1070, 1500'
            }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      </div>
      <div class="image-with-text__text-item grid__item">
        <div
          id="ImageWithText--{{ section.id }}"
          class="image-with-text__content image-with-text__content--{{ section.settings.desktop_content_position }} image-with-text__content--desktop-{{ section.settings.desktop_content_alignment }} image-with-text__content--mobile-{{ section.settings.mobile_content_alignment }} image-with-text__content--{{ section.settings.height }} gradient color-{{ section.settings.color_scheme }} color-scheme-{{ section.id }} content-container"
        >
          {%- comment -%}Render non-scrollable blocks first (heading, caption, ratings){%- endcomment -%}
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'heading' -%}
                <div class="image-with-text__heading {{ block.settings.heading_size }} title-with-highlight" style='--hightlight-color:{{ block.settings.title_highlight_color }}' {{ block.shopify_attributes }} data-text-reveal>
                  {{ block.settings.title }}
                </div>
              {%- when 'rating_stars' -%}
                {% render 'rating-stars-block', block: block, margins: false, block_attributes: true %}
              {%- when 'trustpilot_stars' -%}
                {% render 'trustpilot-stars-block', block: block, margins: false, block_attributes: true %}
              {%- when 'caption' -%}
                <p class="image-with-text__text image-with-text__text--caption {{ block.settings.text_style }} {{ block.settings.text_style }}--{{ block.settings.text_size }} {{ block.settings.text_style }}" {{ block.shopify_attributes }}>
                  {{ block.settings.caption }}
                </p>
            {%- endcase -%}
          {%- endfor -%}

          {%- comment -%}Start scrollable wrapper for content blocks{%- endcomment -%}
          {%- if section.settings.scrollable_text -%}
            <div class="image-with-text__text-scrollable-wrapper">
          {%- endif -%}

          {%- comment -%}Render scrollable content blocks (text, pull_quote, icon_anchor){%- endcomment -%}
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'text' -%}
                <div class="image-with-text__text rte {{ block.settings.text_style }}" {{ block.shopify_attributes }} data-scroll-animate="fade-up" data-scroll-delay="{{ forloop.index | times: 100 }}">
                  {{ block.settings.text }}
                </div>
              {%- when 'pull_quote' -%}
                <blockquote class="pull-quote" {{ block.shopify_attributes }} data-scroll-animate="scale-up" data-scroll-delay="{{ forloop.index | times: 100 }}">
                  {{ block.settings.quote }}
                </blockquote>
              {%- when 'icon_anchor' -%}
                <div class="icon-anchor" {{ block.shopify_attributes }} data-scroll-animate="slide-left" data-scroll-delay="{{ forloop.index | times: 100 }}">
                  <div class="icon-anchor__icon">
                    {%- if block.settings.custom_icon != blank -%}
                      <img src="{{ block.settings.custom_icon | image_url }}" alt="" loading="lazy">
                    {%- elsif block.settings.material_icon != blank -%}
                      <span class="material-symbols-rounded">{{ block.settings.material_icon }}</span>
                    {%- endif -%}
                  </div>
                  <div class="icon-anchor__text">{{ block.settings.subhead }}</div>
                </div>
            {%- endcase -%}
          {%- endfor -%}

          {%- comment -%}Close scrollable wrapper{%- endcomment -%}
          {%- if section.settings.scrollable_text -%}
            </div>
          {%- endif -%}

          {%- comment -%}Render buttons and other non-scrollable blocks after wrapper{%- endcomment -%}
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'button' -%}
                {%- if block.settings.button_label != blank -%}
                  <a
                    {% if block.settings.button_link == blank %}
                      role="link" aria-disabled="true"
                    {% else %}
                      href="{{ block.settings.button_link }}"
                    {% endif %}
                    class="{% if block.settings.mm_style_button %}mm-style-btn-{{ section.id }}{% else %}button{% if block.settings.button_style_secondary %} button--secondary{% else %} button--primary{% endif %}{% endif %}"
                    {{ block.shopify_attributes }}
                  >
                    {{ block.settings.button_label | escape }}
                  </a>
                {%- endif -%}
              {%- when 'button_magic_mind' -%}
                {%- assign btn_align = block.settings.button_alignment | default: 'left' -%}
                <div class="magic-mind-btn-wrapper" style="width: 100%; display: flex; justify-content: {% if btn_align == 'left' %}flex-start{% elsif btn_align == 'center' %}center{% else %}flex-end{% endif %};" {{ block.shopify_attributes }}>
                  {% render 'magic-mind-button',
                    unique_id: section.id | append: '-' | append: block.id,
                    button_label: block.settings.button_label,
                    button_link: block.settings.button_link,
                    open_in_new_tab: block.settings.open_in_new_tab,
                    text_alignment: block.settings.text_alignment,
                    padding_horizontal: block.settings.padding_horizontal,
                    padding_vertical: block.settings.padding_vertical,
                    margin_top: block.settings.margin_top,
                    margin_bottom: block.settings.margin_bottom,
                    full_width_mobile: block.settings.full_width_mobile
                  %}
                </div>
              {%- when 'atc_button' -%}
                {% if block.settings.atc_product == blank %}
                  <button
                    id="SectionAtcBtn-{{ section.id }}"
                    type="button"
                    class="button main-product-atc button--has-spinner"
                    {% if product.selected_or_first_available_variant.available == false or quantity_rule_soldout %}
                      disabled
                    {% endif %}
                    {{ block.shopify_attributes }}
                  >
                    {{ block.settings.button_label }}
                    <div class="loading-overlay__spinner">
                      <svg
                        aria-hidden="true"
                        focusable="false"
                        class="spinner"
                        viewBox="0 0 66 66"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                      </svg>
                    </div>
                  </button>
                {% else %}
                  {% assign product_form_id = 'section-product-form-' | append: section.id | append: block.id %}
                  {% render 'separate-atc-btn',
                    product: block.settings.atc_product,
                    product_form_id: product_form_id,
                    label: block.settings.button_label,
                    skip_cart: block.settings.atc_skip_cart
                  %}
                {% endif %}
              {%- when 'text_with_icon' -%}
                {% render 'text-with-icon-block', block: block, mobile_align: true, block_attributes: true %}
              {%- when 'image' -%}
                <div
                  class="product-info__image-block product-info__image-block--mobile-alignment"
                  style="--image-width:{{ block.settings.width }}%;--image-alignment:{{ block.settings.alignment }};--mobile-image-alignment:{{ block.settings.mobile_alignment }};--border-radius:{{ block.settings.border_radius | divided_by: 10.0 }}rem;"
                  {{ block.shopify_attributes }}
                >
                  {% if block.settings.image != blank %}
                    <div class="media media--transparent ratio" style="--ratio-percent: {{ 1 | divided_by: block.settings.image.aspect_ratio | times: 100 }}%">
                      {%- capture sizes -%}
                        (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 | times: block.settings.width | divided_by: 100.0 }}px,
                        (min-width: 750px) calc(({{ block.settings.width }}vw - 130px) / 2), calc(({{ block.settings.width }}vw - 50px) / 2)
                      {%- endcapture -%}
                      {{
                        block.settings.image
                        | image_url: width: 1500
                        | image_tag: loading: 'lazy', sizes: sizes, widths: '165, 360, 535, 750, 1070, 1500'
                      }}
                    </div>
                  {% else %}
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                  {% endif %}
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</div>

{%- if section.settings.enable_rotating_images -%}
<script>
  (function() {
    const container = document.querySelector('.rotating-images-container-{{ section.id }}');
    if (!container) return;

    const images = container.querySelectorAll('.rotating-image');
    if (images.length <= 1) return;

    const interval = parseInt(container.dataset.interval) || 3000;
    let currentIndex = 0;

    function showNextImage() {
      images[currentIndex].classList.remove('rotating-image--active');
      currentIndex = (currentIndex + 1) % images.length;
      images[currentIndex].classList.add('rotating-image--active');
    }

    setInterval(showNextImage, interval);
  })();
</script>
{%- endif -%}

