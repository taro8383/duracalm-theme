{%- if section.settings.enable_quick_add -%}
  <link rel="stylesheet" href="{{ 'quick-add.css' | asset_url }}" media="print" onload="this.media='all'">
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Section custom background color */
  {% if section.settings.section_background_color != blank %}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.section_background_color }};
  }
  {% endif %}

  /* Product card custom background color */
  {% if section.settings.card_background_color != blank %}
  #shopify-section-{{ section.id }} .card {
    background: {{ section.settings.card_background_color }} !important;
    --color-background: {{ section.settings.card_background_color }};
    --gradient-background: {{ section.settings.card_background_color }};
  }
  #shopify-section-{{ section.id }} .card__content {
    background: transparent !important;
  }
  {% endif %}

  /* Heading Customization */
  #shopify-section-{{ section.id }} .related-products__heading {
    {% if section.settings.heading_font_family != blank %}
    font-family: {{ section.settings.heading_font_family }};
    {% endif %}
    {% if section.settings.heading_text_size > 0 %}
    font-size: {{ section.settings.heading_text_size }}px;
    {% endif %}
    {% if section.settings.heading_color != blank %}
    color: {{ section.settings.heading_color }};
    {% endif %}
    {% if section.settings.heading_alignment == 'left' %}
    text-align: left;
    {% elsif section.settings.heading_alignment == 'center' %}
    text-align: center;
    {% elsif section.settings.heading_alignment == 'right' %}
    text-align: right;
    {% endif %}
    {% if section.settings.heading_padding_top != blank %}
    padding-top: {{ section.settings.heading_padding_top }}px;
    {% endif %}
    {% if section.settings.heading_padding_bottom != blank %}
    padding-bottom: {{ section.settings.heading_padding_bottom }}px;
    {% endif %}
    {% if section.settings.heading_padding_left != blank %}
    padding-left: {{ section.settings.heading_padding_left }}px;
    {% endif %}
    {% if section.settings.heading_padding_right != blank %}
    padding-right: {{ section.settings.heading_padding_right }}px;
    {% endif %}
    {% if section.settings.heading_margin_top != blank %}
    margin-top: {{ section.settings.heading_margin_top }}px;
    {% endif %}
    {% if section.settings.heading_margin_bottom != blank %}
    margin-bottom: {{ section.settings.heading_margin_bottom }}px;
    {% endif %}
    {% if section.settings.heading_margin_left != blank %}
    margin-left: {{ section.settings.heading_margin_left }}px;
    {% endif %}
    {% if section.settings.heading_margin_right != blank %}
    margin-right: {{ section.settings.heading_margin_right }}px;
    {% endif %}
  }

  /* Minimal Layout - Compact Card Grid */
  {% if section.settings.enable_minimal_layout %}
  #shopify-section-{{ section.id }} .product-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: {{ section.settings.grid_column_gap | default: 24 }}px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .grid__item {
    flex: 0 0 auto;
    width: {{ section.settings.compact_card_width | default: 200 }}px;
    max-width: {{ section.settings.compact_card_width | default: 200 }}px;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .grid__item {
      {% if section.settings.columns_mobile == '2' %}
      width: calc(50% - {{ section.settings.grid_column_gap | default: 24 | divided_by: 2 }}px);
      max-width: calc(50% - {{ section.settings.grid_column_gap | default: 24 | divided_by: 2 }}px);
      {% else %}
      width: {{ section.settings.compact_card_width_mobile | default: 160 }}px;
      max-width: {{ section.settings.compact_card_width_mobile | default: 160 }}px;
      {% endif %}
    }
  }

  /* Minimal card styling */
  #shopify-section-{{ section.id }} .card {
    background: transparent;
    border: none;
    box-shadow: none;
  }

  #shopify-section-{{ section.id }} .card__media {
    margin-bottom: 8px;
    border-radius: {{ section.settings.card_border_radius | default: 8 }}px;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .card__content {
    padding: 0;
    text-align: {{ section.settings.card_text_alignment | default: 'center' }};
  }

  #shopify-section-{{ section.id }} .card__heading {
    font-size: {{ section.settings.card_title_size | default: 14 }}px;
    line-height: 1.3;
    margin: 0 0 4px 0;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  #shopify-section-{{ section.id }} .price {
    font-size: {{ section.settings.card_price_size | default: 13 }}px;
    justify-content: {{ section.settings.card_text_alignment | default: 'center' }};
    margin: 0;
  }

  /* Hide elements in minimal mode based on settings */
  {% unless section.settings.show_vendor %}
  #shopify-section-{{ section.id }} .card__vendor {
    display: none !important;
  }
  {% endunless %}

  {% unless section.settings.show_rating %}
  #shopify-section-{{ section.id }} .rating {
    display: none !important;
  }
  {% endunless %}

  {% unless section.settings.enable_quick_add %}
  #shopify-section-{{ section.id }} .quick-add {
    display: none !important;
  }
  {% endunless %}
  {% endif %}

  /* Product Card Size & Positioning (for non-minimal mode) */
  {% unless section.settings.enable_minimal_layout %}
  {% if section.settings.card_max_width > 0 %}
  #shopify-section-{{ section.id }} .grid__item {
    max-width: {{ section.settings.card_max_width }}px;
  }
  {% endif %}

  {% if section.settings.card_width > 0 %}
  #shopify-section-{{ section.id }} .card {
    width: {{ section.settings.card_width }}px;
  }
  {% endif %}

  #shopify-section-{{ section.id }} .card {
    {% if section.settings.card_padding_top > 0 %}
    padding-top: {{ section.settings.card_padding_top }}px;
    {% endif %}
    {% if section.settings.card_padding_bottom > 0 %}
    padding-bottom: {{ section.settings.card_padding_bottom }}px;
    {% endif %}
    {% if section.settings.card_padding_left > 0 %}
    padding-left: {{ section.settings.card_padding_left }}px;
    {% endif %}
    {% if section.settings.card_padding_right > 0 %}
    padding-right: {{ section.settings.card_padding_right }}px;
    {% endif %}
    {% if section.settings.card_margin_top > 0 %}
    margin-top: {{ section.settings.card_margin_top }}px;
    {% endif %}
    {% if section.settings.card_margin_bottom > 0 %}
    margin-bottom: {{ section.settings.card_margin_bottom }}px;
    {% endif %}
    {% if section.settings.card_margin_left > 0 %}
    margin-left: {{ section.settings.card_margin_left }}px;
    {% endif %}
    {% if section.settings.card_margin_right > 0 %}
    margin-right: {{ section.settings.card_margin_right }}px;
    {% endif %}
  }

  /* Grid Gap Customization */
  {% if section.settings.grid_column_gap > 0 %}
  #shopify-section-{{ section.id }} .product-grid {
    column-gap: {{ section.settings.grid_column_gap }}px;
  }
  {% endif %}
  {% if section.settings.grid_row_gap > 0 %}
  #shopify-section-{{ section.id }} .product-grid {
    row-gap: {{ section.settings.grid_row_gap }}px;
  }
  {% endif %}

  /* Card Image Size Control */
  {% if section.settings.card_image_max_width > 0 %}
  #shopify-section-{{ section.id }} .card__media {
    max-width: {{ section.settings.card_image_max_width }}px;
    margin-left: auto;
    margin-right: auto;
  }
  {% endif %}

  /* Auto-center and space evenly */
  {% if section.settings.auto_center_cards %}
  #shopify-section-{{ section.id }} .product-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    {% if section.settings.card_max_width > 0 %}
    {% assign cards_per_row = section.settings.columns_desktop | default: 4 %}
    {% assign container_padding = 100 %}
    {% assign available_space = 'calc(100% - ' | append: container_padding | append: 'px)' %}
    gap: {{ section.settings.grid_column_gap | default: 20 }}px;
    {% endif %}
  }

  #shopify-section-{{ section.id }} .grid__item {
    {% if section.settings.card_max_width > 0 %}
    flex: 0 0 {{ section.settings.card_max_width }}px;
    max-width: {{ section.settings.card_max_width }}px;
    width: {{ section.settings.card_max_width }}px;
    {% else %}
    flex: 1 1 auto;
    max-width: 100%;
    {% endif %}
  }
  {% endif %}

  /* Force grid display for related products */
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .grid.product-grid {
      display: grid !important;
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    }
  }
  {% endunless %}

  /* Quick Add Button Styling */
  {% if section.settings.enable_quick_add and section.settings.quick_add_style == 'magic_mind' %}
  #shopify-section-{{ section.id }} .quick-add__submit {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    text-transform: none;
    border: 2px solid #7B92C8;
    border-radius: 8px;
    color: #ffffff;
    background: transparent;
    cursor: pointer;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .quick-add__submit::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #7B92C8 0%, #ddbea8 50%, #f3dfc1 100%);
    background-size: 200% 200%;
    opacity: 0;
    transition: opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: -1;
  }

  #shopify-section-{{ section.id }} .quick-add__submit:hover::before {
    opacity: 1;
    background-position: 100% 0;
  }

  #shopify-section-{{ section.id }} .quick-add__submit:hover {
    color: #ffffff;
    border-color: transparent;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(123, 146, 200, 0.3);
  }
  {% endif %}
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient no-js-hidden content-for-grouping {% unless section.settings.enable_minimal_layout %}animate-section animate--hidden{% endunless %}">
  {% if section.settings.display_id %}
    <copy-button class='section-id-btn button' data-content="#shopify-section-{{ section.id }}" data-success="false">
      <span class="copy-text">Click to copy section ID</span>
      <span class="copy-success">ID copied successfully!</span>
    </copy-button>
  {% endif %}
  <product-recommendations
    class="related-products page-width section-{{ section.id }}-padding isolate"
    data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.products_to_show }}"
  >
    {% assign shown_products = 0 %}
    {% assign display_heading = false %}

    {% comment %} Get recommended products {% endcomment %}
    {% if recommendations.performed and recommendations.products_count > 0 %}
      {% assign display_heading = true %}
      {% for recommendation in recommendations.products %}
        {% unless recommendation.tags contains 'collection-hidden' %}
          {% assign shown_products = shown_products | plus: 1 %}
        {% endunless %}
      {% endfor %}
    {% endif %}

    {% comment %} Fallback: If no recommendations, use collection products {% endcomment %}
    {% if shown_products == 0 %}
      {% assign display_heading = true %}
      {% assign fallback_products = collections.all.products | where: "id", product.id | reverse %}
      {% assign shown_products = section.settings.products_to_show %}
    {% endif %}

    {% if display_heading %}
      <h2 class="related-products__heading {{ section.settings.heading_size }} title-with-highlight {% unless section.settings.enable_minimal_layout %}animate-item animate-item--child index-0{% endunless %}" style='--hightlight-color:{{ section.settings.title_highlight_color }}'>
        {{ section.settings.title }}
      </h2>
      {% if section.settings.enable_minimal_layout %}
        <ul class="product-grid" role="list">
      {% else %}
        <ul class="grid product-grid grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down" role="list">
      {% endif %}
        {% assign product_index = 0 %}

        {% comment %} Show recommended products first {% endcomment %}
        {% if recommendations.performed and recommendations.products_count > 0 %}
          {% for recommendation in recommendations.products %}
            {% unless recommendation.tags contains 'collection-hidden' %}
              <li class="grid__item {% unless section.settings.enable_minimal_layout %}animate-item animate-item--child{% endunless %}" {% unless section.settings.enable_minimal_layout %}style="--index:{{ product_index }};"{% endunless %}>
                {% render 'card-product',
                  card_product: recommendation,
                  media_aspect_ratio: section.settings.image_ratio,
                  show_secondary_image: section.settings.show_secondary_image,
                  show_vendor: section.settings.show_vendor,
                  show_quick_add: section.settings.enable_quick_add,
                  show_rating: section.settings.show_rating,
                  lazy_load: true
                %}
              </li>
              {% assign product_index = product_index | plus: 1 %}
            {% endunless %}
          {% endfor %}
        {% endif %}

        {% comment %} Fill remaining slots with collection products {% endcomment %}
        {% assign target_count = section.settings.products_to_show %}
        {% if product_index < target_count %}
          {% assign needed = target_count | minus: product_index %}
          {% assign current_id = product.id %}
          {% assign added = 0 %}
          {% for coll_product in collections.all.products limit: 30 %}
            {% if added < needed and coll_product.id != current_id %}
              {% assign already_in_list = false %}
              {% for rec in recommendations.products %}
                {% if rec.id == coll_product.id %}
                  {% assign already_in_list = true %}
                {% endif %}
              {% endfor %}
              {% unless already_in_list or coll_product.tags contains 'collection-hidden' %}
                <li class="grid__item {% unless section.settings.enable_minimal_layout %}animate-item animate-item--child{% endunless %}" {% unless section.settings.enable_minimal_layout %}style="--index:{{ product_index }};"{% endunless %}>
                  {% render 'card-product',
                    card_product: coll_product,
                    media_aspect_ratio: section.settings.image_ratio,
                    show_secondary_image: section.settings.show_secondary_image,
                    show_vendor: section.settings.show_vendor,
                    show_quick_add: section.settings.enable_quick_add,
                    show_rating: section.settings.show_rating,
                    lazy_load: true
                  %}
                </li>
                {% assign product_index = product_index | plus: 1 %}
                {% assign added = added | plus: 1 %}
              {% endunless %}
            {% endif %}
          {% endfor %}
        {% endif %}
      </ul>
    {% endif %}
  </product-recommendations>
</div>

{% schema %}
{
  "name": "Related products minimal",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "display_id",
      "label": "Display section ID",
      "info": "ID is used in the Sections group section to merge 2 sections. ID can also be put inside any button link and the button will scroll to this section.",
      "default": false
    },
    {
      "type": "paragraph",
      "content": "Dynamic recommendations change and improve with time. Learn more"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "You may also like",
      "label": "Heading",
      "info": "Bold certain words to highlight them with a different color."
    },
    {
      "type": "color",
      "id": "title_highlight_color",
      "label": "Heading highlight color",
      "default": "#6D388B"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h2",
      "label": "Heading size"
    },
    {
      "type": "header",
      "content": "Heading Customization"
    },
    {
      "type": "range",
      "id": "heading_text_size",
      "min": 0,
      "max": 72,
      "step": 1,
      "default": 18,
      "unit": "px",
      "label": "Heading text size",
      "info": "Set to 0 to use default theme size"
    },
    {
      "type": "text",
      "id": "heading_font_family",
      "label": "Heading font family",
      "info": "Enter a font family (e.g., 'Playfair Display', sans-serif). Leave empty to use theme default."
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading text color",
      "info": "Select a color to override the default theme color"
    },
    {
      "type": "header",
      "content": "Heading Padding"
    },
    {
      "type": "range",
      "id": "heading_padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px",
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "heading_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 16,
      "unit": "px",
      "label": "Padding bottom"
    },
    {
      "type": "range",
      "id": "heading_padding_left",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px",
      "label": "Padding left"
    },
    {
      "type": "range",
      "id": "heading_padding_right",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px",
      "label": "Padding right"
    },
    {
      "type": "header",
      "content": "Heading Margin"
    },
    {
      "type": "range",
      "id": "heading_margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px",
      "label": "Margin top"
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px",
      "label": "Margin bottom"
    },
    {
      "type": "range",
      "id": "heading_margin_left",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px",
      "label": "Margin left"
    },
    {
      "type": "range",
      "id": "heading_margin_right",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px",
      "label": "Margin right"
    },
    {
      "type": "header",
      "content": "Minimal Layout Options"
    },
    {
      "type": "checkbox",
      "id": "enable_minimal_layout",
      "label": "Enable compact minimal layout",
      "default": true,
      "info": "When enabled, cards will be displayed in a compact horizontal row. Disable to use standard grid layout."
    },
    {
      "type": "range",
      "id": "compact_card_width",
      "min": 100,
      "max": 400,
